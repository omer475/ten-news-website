# PART 4: PERSONALIZATION ENGINE

## Core Algorithm (TypeScript)

```typescript
// Types
interface Article {
  id: string;
  title: string;
  url: string;
  source: string;
  category: string;
  base_score: number;
  countries: string[];
  topics: string[];
  image_url?: string;
  published_at: string;
  created_at: string;
}

interface User {
  id: string;
  home_country: string;
  followed_countries: string[];
  followed_topics: string[];
}

interface ScoredArticle extends Article {
  final_score: number;
  match_reasons: string[]; // For debugging/display: why this article was boosted
}

/**
 * Calculate personalized score for an article based on user preferences
 */
function calculateFinalScore(article: Article, user: User): ScoredArticle {
  let score = article.base_score;
  const matchReasons: string[] = [];
  
  // 1. HOME COUNTRY BOOST (+150)
  // The user's home country gets the highest boost
  if (article.countries.includes(user.home_country)) {
    score += PERSONALIZATION_CONFIG.HOME_COUNTRY_BOOST;
    matchReasons.push(`Home country: ${user.home_country}`);
  }
  
  // 2. FOLLOWED COUNTRIES BOOST (+75 for 1, +100 for 2+)
  // Additional countries the user follows
  const followedCountryMatches = article.countries.filter(
    country => user.followed_countries.includes(country)
  );
  if (followedCountryMatches.length >= 2) {
    score += PERSONALIZATION_CONFIG.FOLLOWED_COUNTRY_MULTIPLE_BOOST;
    matchReasons.push(`Followed countries: ${followedCountryMatches.join(', ')}`);
  } else if (followedCountryMatches.length === 1) {
    score += PERSONALIZATION_CONFIG.FOLLOWED_COUNTRY_SINGLE_BOOST;
    matchReasons.push(`Followed country: ${followedCountryMatches[0]}`);
  }
  
  // 3. TOPIC BOOST (+50 for 1, +80 for 2, +100 for 3+)
  // Topics the user is interested in
  const topicMatches = article.topics.filter(
    topic => user.followed_topics.includes(topic)
  );
  if (topicMatches.length >= 3) {
    score += PERSONALIZATION_CONFIG.TOPIC_TRIPLE_PLUS_BOOST;
    matchReasons.push(`Topics: ${topicMatches.join(', ')}`);
  } else if (topicMatches.length === 2) {
    score += PERSONALIZATION_CONFIG.TOPIC_DOUBLE_BOOST;
    matchReasons.push(`Topics: ${topicMatches.join(', ')}`);
  } else if (topicMatches.length === 1) {
    score += PERSONALIZATION_CONFIG.TOPIC_SINGLE_BOOST;
    matchReasons.push(`Topic: ${topicMatches[0]}`);
  }
  
  return {
    ...article,
    final_score: score,
    match_reasons: matchReasons,
  };
}

/**
 * Get personalized "For You" feed for a user
 */
function getForYouFeed(articles: Article[], user: User, limit?: number): ScoredArticle[] {
  // Calculate personalized scores for all articles
  const scoredArticles = articles.map(article => 
    calculateFinalScore(article, user)
  );
  
  // Sort by final_score descending (highest first)
  scoredArticles.sort((a, b) => b.final_score - a.final_score);
  
  // Apply limit if specified
  if (limit) {
    return scoredArticles.slice(0, limit);
  }
  
  return scoredArticles;
}

/**
 * Get global "Today" feed (same for all users)
 */
function getTodayFeed(articles: Article[]): Article[] {
  // Filter to only high base_score articles (no personalization)
  const topArticles = articles.filter(
    article => article.base_score >= PERSONALIZATION_CONFIG.TODAY_FEED_MIN_SCORE
  );
  
  // Sort by base_score descending
  topArticles.sort((a, b) => b.base_score - a.base_score);
  
  // Return top N articles
  return topArticles.slice(0, PERSONALIZATION_CONFIG.TODAY_FEED_MAX_ARTICLES);
}
```

